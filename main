    {0x23,0x13,0x08,0x64,0x62}, /* 37  '%' */
    {0x36,0x49,0x55,0x22,0x50}, /* 38  '&' */
    {0x00,0x05,0x03,0x00,0x00}, /* 39  '\''*/
