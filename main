#include "stm32f429xx.h"

/* ================================================================
 *  WHACK-A-MOLE  —  STM32F429ZI  (Nucleo-144 / Discovery)
 *  Original game logic UNTOUCHED.
 *  Added: LTDC + ILI9341 LCD (SPI5) for score / time / splash.
 *
 *  LED mapping (unchanged):
 *    0 = PB5  (top-left)     Button: PE0
 *    1 = PB9  (top-right)    Button: PB8
 *    2 = PB7  (bottom-left)  Button: PB4
 *    3 = PE1  (bottom-right) Button: PB6
 *
 *  ILI9341 SPI wiring (STM32F429I-DISC1 on-board LCD):
 *    SPI5  SCK  -> PF7   (AF5)
 *    SPI5  MOSI -> PF9   (AF5)
 *    CS         -> PC2   (GPIO out)
 *    DC/RS      -> PD13  (GPIO out)
 *    RST        -> PD12  (GPIO out) -- or tie to 3V3 and skip HW reset
 *    (MISO not needed — write-only)
 *
 *  LCD resolution: 240 × 320 (ILI9341), landscape used as 320 × 240
 * ================================================================ */

/* ----------------------------------------------------------------
 *  Forward declarations
 * ---------------------------------------------------------------- */
void timer2_delay_ms(int ms);
uint32_t simple_rand(void);

/* LCD subsystem */
static void lcd_init(void);
static void lcd_fill(uint16_t colour);
static void lcd_draw_rect(int x, int y, int w, int h, uint16_t colour);
static void lcd_draw_char(int x, int y, char c, uint16_t fg, uint16_t bg, int scale);
static void lcd_draw_string(int x, int y, const char *s, uint16_t fg, uint16_t bg, int scale);
static void lcd_draw_number(int x, int y, int n, uint16_t fg, uint16_t bg, int scale);
static void lcd_splash(void);
static void lcd_update_hud(void);
static void lcd_hit_flash(void);
static void lcd_miss_flash(void);

/* ----------------------------------------------------------------
 *  Game state  (original, untouched names / types)
 * ---------------------------------------------------------------- */
volatile int      active_led  = 0;
volatile int      score       = 0;
volatile uint32_t rand_seed   = 1;

/* Extra state used by LCD HUD only */
static volatile uint32_t game_ticks_ms = 0;   /* rough elapsed ms   */
static volatile int      misses        = 0;    /* wrong-button count */

/* ================================================================
 *  COLOUR PALETTE  (RGB565)
 * ================================================================ */
#define C_BLACK    0x0000u
#define C_WHITE    0xFFFFu
#define C_BG       0x0841u   /* dark navy                          */
#define C_PANEL    0x10A2u   /* slightly lighter panel             */
#define C_GREEN    0x07E0u
#define C_LIME     0x87E0u
#define C_RED      0xF800u
#define C_YELLOW   0xFFE0u
#define C_ORANGE   0xFD20u
#define C_CYAN     0x07FFu
#define C_MAGENTA  0xF81Fu
#define C_GRAY     0x4A69u
#define C_DARKGRAY 0x2104u
#define C_GOLD     0xFEA0u
#define C_MOLE     0x8C00u   /* brown-ish mole colour              */
#define C_GRASS    0x0400u   /* dark green grass                   */

/* ================================================================
 *  TINY 5×7 FONT  (ASCII 32-90)
 *  Each entry = 5 column bytes; bit0 = topmost pixel of column
 * ================================================================ */
static const uint8_t font5x7[][5] = {
    {0x00,0x00,0x00,0x00,0x00}, /* 32  ' ' */
    {0x00,0x00,0x5F,0x00,0x00}, /* 33  '!' */
